# Kopier til .env.local (git-ignorert) og fyll inn ekte verdier lokalt.
# Vite krever VITE_-prefikset for at variabelen skal nå klientbundelen — og
# det betyr samtidig at nøklene er lesbare for sluttbruker (akseptert
# risiko for en ren klient-app uten backend, se
# docs/architecture.md#kjente-forutsetninger-og-risikoer).
#
# I CI/produksjon (GitHub Pages) settes de samme variablene som GitHub
# Actions-secrets (Settings → Secrets and variables → Actions):
#   VITE_OMDB_API_KEY, VITE_MOTN_API_KEY, VITE_FIREBASE_*

# OMDb (søk og titteldata: beskrivelse, sjanger, plakat, IMDb-/RT-score).
# Skaff nøkkel: https://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=

# Movie of the Night / Streaming Availability API (strømmetilgjengelighet).
# Skaff nøkkel (gratisplan, ingen betalingsinfo): MOTN Developers Platform
VITE_MOTN_API_KEY=

# Firebase (DB-migrering: anonym auth + Firestore, se
# docs/plans/watchlist-database-migrering.md). Verdiene er designet for å
# være offentlige (sikkerheten ligger i Firestore Security Rules, ikke i
# hemmelighold), men settes likevel som GitHub Actions-secrets for
# konsistens med de andre nøklene over. Skaff verdiene fra Firebase Console
# → Project settings → General → Your apps (Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
